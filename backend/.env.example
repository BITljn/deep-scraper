# ── 数据库 ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tarco:tarco_dev_2025@localhost:5432/tarco

# ── 长桥 OpenAPI ────────────────────────────────────────
# 在 https://open.longbridgeapp.com 注册开发者账号后获取
LONGBRIDGE_APP_KEY=your_app_key
LONGBRIDGE_APP_SECRET=your_app_secret
LONGBRIDGE_ACCESS_TOKEN=your_access_token

# ── 采集标的 ────────────────────────────────────────────
COLLECT_SYMBOL=TSLA.US
LONGBRIDGE_TAX_START_YEAR=2019
LONGBRIDGE_TAX_SYMBOLS=
LONGBRIDGE_TAX_REQUEST_INTERVAL_SECONDS=0.6
LONGBRIDGE_TAX_ORDER_DETAIL_INTERVAL_SECONDS=1.5
LONGBRIDGE_TAX_MAX_RETRIES=5
LONGBRIDGE_TAX_BACKOFF_SECONDS=3.0
LONGBRIDGE_TAX_CACHE_ENABLED=true
LONGBRIDGE_TAX_CACHE_DIR=.cache/longbridge_tax_sdk
TAX_FX_SOURCE_URL=https://www.chinamoney.com.cn/ags/ms/cm-u-bk-ccpr/CcprHisNew
TAX_FX_SAFE_HISTORY_URL=https://www.safe.gov.cn/safe/file/file/20260106/0f147e5357eb4c12a6406fc575cc21e8.xlsx

# ── Musk 推文 ──────────────────────────────────────────
MUSK_USERNAME=elonmusk

# ── twscrape: X (Twitter) 账号 ──────────────────────────
# JSON 数组, 每个元素: {"username","password","email","email_password","cookies"(可选)}
# cookies 方式更稳定; 不提供 cookies 时 twscrape 会执行登录流程
# TWITTER_ACCOUNTS=[{"username":"u1","password":"p1","email":"u1@mail.com","email_password":"ep1","cookies":"auth_token=xx;ct0=yy"}]
TWITTER_ACCOUNTS=[]

# ── 采集器开关 ──────────────────────────────────────────
COLLECTOR_QUOTE_ENABLED=true
COLLECTOR_TOPIC_ENABLED=true
COLLECTOR_TWEET_ENABLED=false
COLLECTOR_VIX_ENABLED=false
COLLECTOR_TAX_ENABLED=false

# ── 日志 ───────────────────────────────────────────────
LOG_DIR=logs
LOG_LEVEL=INFO
